      "governance_ready",
      "capital_ready",
      "execution_ready"
    ],
    "required_flags": [
      "mandate_signed",
      "fee_secured"
    ],
    "rule": "No mandate -> no Gate 2+ progression"
  },
  "pre_mandate_phase": {
    "positioning_only": true,
    "disallow": [
