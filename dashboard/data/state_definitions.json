        "no_commitment_path"
      ],
      "next_state": "execution_ready",
      "max_score_ceiling": 85
    },
    "execution_ready": {
      "order": 5,
      "required_conditions": [
        "required_prior_transitions_completed",
        "critical_constraints_resolved",
        "scope_clear_for_execution",
        "remaining_unknowns_not_decision_blocking",
        "formal_handoff_package_ready"
