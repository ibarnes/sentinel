      "max_score_ceiling": 65
    },
    "capital_ready": {
      "order": 4,
      "required_conditions": [
        "capital_stack_defined",
        "commercial_model_documented",
        "fundability_constraints_known",
        "viability_or_strategic_evidence_present",
        "commitment_path_identified"
