        "no_linked_evidence",
        "no_buyer_or_actor_path"
      ],
      "next_state": "architecture_defined",
      "max_score_ceiling": 25
    },
    "architecture_defined": {
      "order": 2,
      "required_conditions": [
        "thesis_documented",
        "constraint_resolution_logic_documented",
        "roles_mapped",
        "dependencies_identified",
        "transition_path_defined",
        "mandate_signed",
        "fee_secured"
      ],
      "blocks": [
