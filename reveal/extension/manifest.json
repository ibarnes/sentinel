{
  "manifest_version": 3,
  "name": "Reveal Capture",
  "version": "0.1.0",
  "description": "Capture browser interactions and send raw events to Reveal ingestion API.",
  "permissions": ["storage", "tabs", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>", "http://localhost:4180/*", "https://*/reveal/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Reveal Capture"
  }
}
